<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Sportsbook Master Ticker (Ahlers Arcade Edition)</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <style>
        /* --- ORIGINAL MASTER SCALING & STYLES --- */
        :root { --ticker-height: 22vh; }
        body, html { margin: 0; padding: 0; width: 100vw; height: 100vh; background: black; overflow: hidden; color: white; font-family: 'Inter', sans-serif; cursor: none; font-size: 3.5vh; }
        body.remote-active .tv-wrapper { display: none !important; }
        body:not(.remote-active) #remote-controller { display: none !important; }
        .tv-wrapper { position: absolute; top: 0; left: 0; width: 100vw; height: 100vh; display: flex; justify-content: center; align-items: center; overflow: hidden; }

        /* CLEAN FS TOGGLE */
        #fs-toggle { position: fixed; top: 2vh; right: 2vw; z-index: 10000; background: none; border: none; color: #fff; font-size: 4vh; cursor: pointer; opacity: 0.3; transition: all 0.3s ease; }
        #fs-toggle:hover { opacity: 1; color: #ff007f; text-shadow: 0 0 15px #ff007f; }

        /* SETTINGS UI */
        #settings-gear { position: fixed; top: 2vh; right: 8vw; z-index: 15000; font-size: 5vh; cursor: pointer; opacity: 0.2; transition: all 0.3s ease; color: white; }
        #settings-gear:hover { opacity: 1; color: #ff007f; transform: rotate(90deg); }
        #settings-modal { position: fixed; inset: 0; background: rgba(0,0,0,0.95); backdrop-filter: blur(15px); z-index: 20000; display: none; justify-content: center; align-items: center; }
        .settings-card { background: #0a0a0a; border: 2px solid #ff007f; width: 85vw; max-height: 90vh; border-radius: 2vh; padding: 4vh; overflow-y: auto; }
        .settings-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 4vh; }
        .settings-section h3 { color: #ff007f; text-transform: uppercase; font-weight: 900; border-bottom: 1px solid #333; margin-bottom: 2vh; font-size: 2.8vh; }
        .toggle-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5vh; font-size: 2vh; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5vh; }

        /* TICKER - CONTINUOUS SCROLL */
        #sports-ticker { position: absolute; bottom: 0; left: 0; width: 100%; height: var(--ticker-height); background: rgba(0,0,0,0.95); backdrop-filter: blur(20px); border-top: 0.6vh solid #ff007f; z-index: 100; display: flex; align-items: center; overflow: hidden; white-space: nowrap; box-shadow: 0 -1vh 3vh rgba(255, 0, 127, 0.6); }
        #ticker-track { display: inline-flex; animation: scrollTicker 80s linear infinite; height: 100%; align-items: center; width: max-content; } 
        @keyframes scrollTicker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

        /* TICKER ITEMS - STRICT SIDE-BY-SIDE LOCK */
        .ticker-section-head { display: inline-flex; align-items: center; justify-content: center; padding: 0 3vw; height: 100%; color: #ff007f; font-size: 4rem; letter-spacing: 0.3vw; font-weight: 900; vertical-align: middle; }
        .score-item { display: inline-flex !important; flex-direction: row !important; align-items: center !important; padding: 0 5vw; height: 100%; vertical-align: middle; flex-wrap: nowrap !important; }
        .team-box { display: flex !important; flex-direction: row !important; align-items: center !important; flex-wrap: nowrap !important; }
        .team-logo { width: 11vh; height: 11vh; object-fit: contain; margin-right: 1.5vw; flex-shrink: 0; } 
        .team-score { font-size: 4.8rem; line-height: 1; color: #00ffff; margin-right: 0.8vw; font-weight: 900; }
        .vs-label { color: #444; font-size: 2.7rem; margin: 0 2.5vw; font-weight: bold; }
        .game-status { margin-left: 2vw; color: #facc15; font-size: 2.7rem; text-transform: uppercase; letter-spacing: 0.1vw; }
        .live-pulse { animation: pulseRed 1s infinite; color: #ff0000; font-weight: 900; margin-right: 1.5vw; font-size: 2.7rem; }

        /* SLIDES & GRIDS - STRICT SIDE-BY-SIDE SCORE LOCK */
        .slide-screen { position: absolute; inset: 0; z-index: 10; display: none; flex-direction: column; padding: 2vh 4vh; font-family: 'Share Tech Mono', monospace; align-items: center; overflow: hidden; }
        .screen-header { font-size: 9.5vh; font-weight: 900; color: #fff; text-transform: uppercase; letter-spacing: 1vh; margin-bottom: 2vh; margin-top: 1vh; text-shadow: 0 0 15px rgba(0, 255, 255, 0.9); z-index: 20; border-bottom: 0.6vh solid #00ffff; padding-bottom: 1vh; width: 95%; text-align: center; }
        .content-viewport { width: 95%; height: 62vh; overflow: hidden; position: relative; z-index: 20; padding-bottom: var(--ticker-height); }
        .grid-track { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2vw; padding-bottom: 10vh; }
        .info-card { background: rgba(0, 20, 30, 0.85); border: 1px solid #00aaaa; border-left: 1vh solid #00ffff; border-radius: 1vh; display: flex; flex-direction: column; padding: 2.5vh; box-shadow: 0 0 2vh rgba(0, 255, 255, 0.1); backdrop-filter: blur(5px); }
        .card-row { display: flex !important; flex-direction: row !important; justify-content: space-between !important; align-items: center !important; margin-bottom: 1.5vh; width: 100%; }
        .card-team { display: flex; align-items: center; gap: 2vh; font-size: 5.2vh; font-weight: 900; color: white; text-transform: uppercase; } 
        .card-team img { width: 8.2vh; height: 8.2vh; object-fit: contain; } 
        .card-val-lg { font-weight: 900; color: #facc15; font-size: 5.7vh; } 
        .card-meta { display: flex; justify-content: space-between; border-bottom: 2px solid #004444; padding-bottom: 1vh; margin-bottom: 1.5vh; font-size: 3.5vh; color: #00aaaa; font-weight: 900; }
        .card-footer { margin-top: auto; padding-top: 1.2vh; border-top: 2px dashed #004444; display: flex; justify-content: space-between; align-items: center; color: #aaa; font-size: 3.5vh; }

        /* STANDINGS & LISTS */
        .list-track { display: flex; flex-direction: column; gap: 1.5vh; padding-bottom: 10vh; width: 90%; margin: 0 auto; }
        .rank-row { display: flex; align-items: center; background: rgba(0, 20, 30, 0.9); border-left: 1vh solid #facc15; padding: 2vh 2.5vh; border-radius: 0.8vh; margin-bottom: 1.5vh; width: 100%; }
        .rank-num { font-size: 6.8vh; color: #facc15; font-weight: 900; width: 12vh; text-align: center; }
        .rank-logo { width: 10vh; height: 10vh; object-fit: contain; margin: 0 3vh; }
        .rank-name { font-size: 5.4vh; color: white; font-weight: 900; flex: 1; }
        .rank-rec { font-size: 4.3vh; color: #aaa; margin-left: auto; font-weight: 900; }

        .standings-track { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5vw; width: 100%; padding-bottom: 15vh; }
        .division-block { background: rgba(0, 20, 30, 0.7); border: 1px solid #333; border-radius: 1.2vh; padding: 2vh; margin-bottom: 2.5vh; }
        .division-header { color: #facc15; font-size: 3.8vh; font-weight: 900; text-transform: uppercase; border-bottom: 3px solid #00aaaa; margin-bottom: 1.5vh; }
        .st-row { display: flex; align-items: center; padding: 1vh 0; border-bottom: 1px solid rgba(255,255,255,0.1); font-size: 3.8vh; font-weight: 900; }
        .st-logo { width: 4.8vh; height: 4.8vh; object-fit: contain; margin: 0 1.5vh; }
        .st-name { flex: 1; color: white; text-transform: uppercase; }
        .st-rec { color: #00ffff; font-weight: 900; }

        /* MY SQUAD SLIDE */
        .squad-layout { display: flex; width: 100%; height: 100%; gap: 4vw; }
        .squad-col { flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative; }
        .squad-header { font-size: 4vh; color: #00ffff; font-weight: 900; text-transform: uppercase; border-bottom: 2px solid #00ffff; padding-bottom: 1vh; margin-bottom: 2vh; text-align: center; }
        .squad-game-card { background: rgba(0, 20, 30, 0.9); border-left: 1vh solid #39ff14; padding: 2.5vh; border-radius: 0.8vh; margin-bottom: 1.5vh; display: flex; flex-direction: column; gap: 1vh; box-shadow: 0 0 1.5vh rgba(57, 255, 20, 0.1); }
        .squad-news-card { background: rgba(0, 20, 30, 0.9); border-left: 1vh solid #ff007f; padding: 2.5vh; border-radius: 0.8vh; margin-bottom: 1.5vh; display: flex; flex-direction: column; box-shadow: 0 0 1.5vh rgba(255, 0, 127, 0.1); }

        /* NEWS AGGREGATOR SLIDE */
        .news-row { display: flex; align-items: center; background: rgba(0, 20, 30, 0.9); border-left: 1vh solid #ff007f; padding: 2vh 2.5vh; border-radius: 0.8vh; margin-bottom: 1.5vh; width: 100%; gap: 3vh; box-shadow: 0 0 1.5vh rgba(255, 0, 127, 0.1); }
        .news-thumb { width: 14vh; height: 10vh; object-fit: cover; border-radius: 0.8vh; border: 2px solid #333; flex-shrink: 0; background: #00111a; }
        .news-content { display: flex; flex-direction: column; flex: 1; justify-content: center; }
        .news-title { font-size: 4vh; color: white; font-weight: 900; line-height: 1.2; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .news-source { font-size: 2.8vh; color: #ff007f; font-weight: 900; margin-top: 1vh; text-transform: uppercase; letter-spacing: 0.2vh; }

        /* UFC FIGHT CARD SLIDE */
        .ufc-card { background: rgba(15, 0, 0, 0.85); border: 1px solid #550000; border-left: 1vh solid #ff0000; border-radius: 1vh; display: flex; flex-direction: column; padding: 2.5vh; box-shadow: 0 0 2vh rgba(255, 0, 0, 0.15); position: relative; overflow: hidden; backdrop-filter: blur(5px); }
        .ufc-matchup { display: flex; justify-content: space-between; align-items: center; width: 100%; margin-bottom: 1vh; z-index: 2; position: relative; }
        .fighter-col { display: flex; flex-direction: column; align-items: center; width: 40%; }
        .fighter-img { height: 16vh; object-fit: contain; filter: drop-shadow(0 0 1vh rgba(255,255,255,0.2)); transition: all 0.3s ease; }
        .fighter-img.winner { filter: drop-shadow(0 0 2vh #39ff14); transform: scale(1.05); }
        .fighter-img.loser { filter: grayscale(100%) brightness(0.5); opacity: 0.6; }
        .fighter-name { font-size: 3vh; color: white; font-weight: 900; text-align: center; text-transform: uppercase; margin-top: 1vh; line-height: 1.1; }
        .ufc-center { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 20%; }
        .ufc-vs { font-size: 4.5vh; color: #ff0000; font-weight: 900; font-style: italic; text-shadow: 0 0 10px rgba(255,0,0,0.5); }
        .ufc-meta { display: flex; justify-content: space-between; border-top: 1px dashed #550000; padding-top: 1.5vh; margin-top: auto; font-size: 2.8vh; color: #aaa; z-index: 2; font-weight: bold; text-transform: uppercase; align-items: center;}
        .ufc-live-badge { position: absolute; top: 1vh; left: 50%; transform: translateX(-50%); background: #ff0000; color: white; padding: 0.5vh 2vh; border-radius: 0.5vh; font-size: 2.2vh; font-weight: 900; animation: pulseRed 1s infinite; z-index: 3; letter-spacing: 0.2vh; }
        .ufc-result { font-size: 2.8vh; color: #39ff14; font-weight: 900; text-align: right; text-shadow: 0 0 10px rgba(57,255,20,0.3); }

        /* RETRO TV GUIDE SLIDE */
        .tv-row { display: flex; align-items: stretch; background: rgba(0, 20, 30, 0.85); border-bottom: 2px solid #00aaaa; width: 100%; min-height: 12vh; }
        .tv-row:nth-child(even) { background: rgba(0, 10, 15, 0.95); }
        .tv-channel { width: 28%; background: #00111a; border-right: 4px solid #00ffff; display: flex; justify-content: center; align-items: center; font-size: 4.5vh; font-weight: 900; color: #facc15; text-align: center; padding: 1.5vh; text-transform: uppercase; letter-spacing: 0.2vh; }
        .tv-channel img { max-width: 90%; max-height: 8vh; object-fit: contain; filter: drop-shadow(0 0 5px rgba(255,255,255,0.2)); }
        
        /* THE BULLETPROOF FALLBACK CSS */
        .fallback-logo { display: inline-block; background: rgba(0,255,255,0.1); border: 2px solid #00ffff; color: #fff; padding: 1vh 2vh; border-radius: 1vh; font-size: 3.5vh; box-shadow: 0 0 10px rgba(0,255,255,0.2); text-shadow: none; letter-spacing: normal; }
        
        .tv-program { flex: 1; padding: 2vh 4vh; display: flex; flex-direction: column; justify-content: center; position: relative; }
        .tv-prog-title { font-size: 5.5vh; color: white; font-weight: 900; text-transform: uppercase; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .tv-prog-time { font-size: 3.8vh; color: #00ffff; margin-top: 0.5vh; font-weight: bold; }
        .tv-prog-live { position: absolute; right: 4vh; top: 50%; transform: translateY(-50%); color: #ff0000; font-weight: 900; font-size: 4.5vh; animation: pulseRed 1s infinite; text-shadow: 0 0 10px red; }

        #main-bg { position: absolute; inset: 0; z-index: 0; background: #050505; overflow: hidden; perspective: 100vh; }
        .cyber-grid { position: absolute; top: 0; left: -50%; width: 200%; height: 100%; background-image: linear-gradient(rgba(0, 255, 255, 0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 255, 255, 0.3) 1px, transparent 1px); background-size: 100px 100px; transform: rotateX(45deg); animation: gridMove 20s linear infinite; }
        @keyframes scrollVerticalOnePass { 0% { transform: translateY(0); } 100% { transform: translateY(var(--scroll-end)); } }

        /* REMOTE */
        #remote-controller { position: fixed; inset: 0; z-index: 9999; background: #000; display: none; flex-direction: column; font-family: 'Inter', sans-serif; color: white; padding: 4vh; }
        body.remote-active #remote-controller { display: flex; }
        .r-btn { width: 100%; padding: 20px; margin-bottom: 10px; background: #1a1a1a; border: 1px solid #333; color: white; font-weight: bold; border-radius: 8px; font-size: 3vh; }
    </style>
</head>
<body onmousemove="showCursor()">

    <div class="tv-wrapper" id="main-wrapper">
        <div id="main-bg"><div class="cyber-grid"></div><div class="scanlines"></div></div>
        <div id="settings-gear" onclick="toggleSettings()">⚙️</div>
        <button id="fs-toggle" onclick="if(!document.fullscreenElement) document.documentElement.requestFullscreen(); else document.exitFullscreen();">⛶</button>

        <div id="live-game-screen" class="slide-screen">
            <div class="screen-header" style="color: #ff0000; text-shadow: 0 0 15px red; border-bottom-color: red;">LIVE ACTION</div>
            <div class="content-viewport" id="live-viewport"><div class="grid-track" id="live-grid-track"></div></div>
        </div>

        <div id="mysquad-screen" class="slide-screen">
            <div class="screen-header" style="color: #39ff14; border-bottom-color: #39ff14; text-shadow: 0 0 15px #39ff14;">MY SQUAD DASHBOARD</div>
            <div class="content-viewport" id="mysquad-viewport">
                <div class="squad-layout">
                    <div class="squad-col">
                        <div class="squad-header">UPCOMING GAMES</div>
                        <div id="squad-games-track" style="padding-bottom: 5vh;"></div>
                    </div>
                    <div class="squad-col">
                        <div class="squad-header">LATEST TEAM NEWS</div>
                        <div id="squad-news-track" style="padding-bottom: 5vh;"></div>
                    </div>
                </div>
            </div>
        </div>

        <div id="ufc-screen" class="slide-screen">
            <div class="screen-header" id="ufc-title" style="color: #ff0000; border-bottom-color: #ff0000; text-shadow: 0 0 15px red;">UFC FIGHT NIGHT</div>
            <div class="content-viewport" id="ufc-viewport">
                <div class="grid-track" id="ufc-grid-track"></div>
            </div>
        </div>
        
        <div id="tvguide-screen" class="slide-screen">
            <div class="screen-header" style="color: #00ffff; border-bottom-color: #00ffff; text-shadow: 0 0 15px cyan;">LIVE ON TV</div>
            <div class="content-viewport" id="tvguide-viewport">
                <div class="list-track" id="tvguide-track" style="gap: 0; border: 2px solid #00aaaa; border-radius: 1vh; overflow: hidden; flex-direction: column;"></div>
            </div>
        </div>

        <div id="news-screen" class="slide-screen">
            <div class="screen-header" style="color: #ff007f; border-bottom-color: #ff007f; text-shadow: 0 0 15px #ff007f;">TODAY'S HEADLINES</div>
            <div class="content-viewport" id="news-viewport">
                <div class="list-track" id="news-list-track"></div>
            </div>
        </div>

        <div id="odds-screen" class="slide-screen"><div class="screen-header">TODAY'S LINES</div><div class="content-viewport" id="odds-viewport"><div class="grid-track" id="odds-grid-track"></div></div></div>
        <div id="rankings-screen" class="slide-screen"><div class="screen-header">COLLEGE RANKINGS</div><div class="content-viewport" id="rankings-viewport"><div class="list-track" id="rankings-list-track"></div></div></div>
        <div id="nfl-screen" class="slide-screen"><div class="screen-header">NFL STANDINGS</div><div class="content-viewport" id="nfl-viewport"><div class="standings-track" id="nfl-track"></div></div></div>
        <div id="nba-screen" class="slide-screen"><div class="screen-header">NBA STANDINGS</div><div class="content-viewport" id="nba-viewport"><div class="standings-track" id="nba-track"></div></div></div>
        <div id="nhl-screen" class="slide-screen"><div class="screen-header">NHL STANDINGS</div><div class="content-viewport" id="nhl-viewport"><div class="standings-track" id="nhl-track"></div></div></div>
        <div id="mlb-screen" class="slide-screen"><div class="screen-header">MLB STANDINGS</div><div class="content-viewport" id="mlb-viewport"><div class="standings-track" id="mlb-track"></div></div></div>

        <div id="sports-ticker"><div id="ticker-track">LOADING AHLERS ARCADE...</div></div>
    </div>

    <div id="settings-modal" onclick="if(event.target === this) toggleSettings()">
        <div class="settings-card">
            <h2 style="font-size: 5vh; font-weight: 900; margin-bottom: 4vh; color: #fff; text-align: center;">ARCADE CONTROL CENTER</h2>
            <div class="settings-grid">
                <div class="settings-section">
                    <h3>Features</h3>
                    <div class="toggle-row"><span>My Squad Slide</span> <input type="checkbox" id="set-mySquad" checked onchange="updateSettings()"></div>
                    <div style="margin-bottom: 2vh;">
                        <div style="font-size: 1.8vh; color: #00ffff; margin-bottom: 0.5vh; text-transform: uppercase;">Set Favorite Teams:</div>
                        <input type="text" id="set-mySquadTeams" style="width: 100%; padding: 1vh; border-radius: 0.5vh; background: #1a1a1a; color: white; border: 1px solid #00ffff; font-family: 'Inter', sans-serif;" placeholder="e.g. Hurricanes, Ohio State" onchange="updateSettings()">
                    </div>
                    
                    <div style="margin-bottom: 2vh;">
                        <div style="font-size: 1.8vh; color: #ff007f; margin-bottom: 0.5vh; text-transform: uppercase;">Custom Ticker Marquee:</div>
                        <input type="text" id="set-marqueeMessage" style="width: 100%; padding: 1vh; border-radius: 0.5vh; background: #1a1a1a; color: white; border: 1px solid #ff007f; font-family: 'Inter', sans-serif;" placeholder="e.g. Welcome to the Arcade!" onchange="updateSettings()">
                    </div>
                    
                    <div class="toggle-row"><span>UFC Fight Card Slide</span> <input type="checkbox" id="set-ufc" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>TV Guide Slide</span> <input type="checkbox" id="set-tvGuide" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>Headlines Slide</span> <input type="checkbox" id="set-news" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>Rankings Slide</span> <input type="checkbox" id="set-rankings" checked onchange="updateSettings()"></div>
                </div>
                <div class="settings-section">
                    <h3>Live/Ticker Data</h3>
                    <div class="toggle-row"><span>NFL</span> <input type="checkbox" id="set-showNFL" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>NBA</span> <input type="checkbox" id="set-showNBA" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>NHL</span> <input type="checkbox" id="set-showNHL" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>MLB</span> <input type="checkbox" id="set-showMLB" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>NCAA FB</span> <input type="checkbox" id="set-showCFB" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>NCAA Hoops</span> <input type="checkbox" id="set-showCBB" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>NCAA Base.</span> <input type="checkbox" id="set-showCLB" checked onchange="updateSettings()"></div>
                </div>
                <div class="settings-section">
                    <h3>Expansions & Standings</h3>
                    <div class="toggle-row"><span>NFL Standings</span> <input type="checkbox" id="set-nfl" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>NBA Standings</span> <input type="checkbox" id="set-nba" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>NHL Standings</span> <input type="checkbox" id="set-nhl" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>MLB Standings</span> <input type="checkbox" id="set-mlb" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>CBB Group 50</span> <input type="checkbox" id="set-cbb50" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>CFB Top 75</span> <input type="checkbox" id="set-cfb75" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>Base. Top 50</span> <input type="checkbox" id="set-clb50" checked onchange="updateSettings()"></div>
                </div>
            </div>
            
            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 4vh; border-top: 2px solid #333; padding-top: 4vh;">
                <div style="display: flex; align-items: center; gap: 3vh;">
                    <img id="settings-qr" src="" style="width: 12vh; height: 12vh; border: 2px solid #00ffff; border-radius: 1vh; background: white;">
                    <div>
                        <div style="color: #00ffff; font-size: 3vh; font-weight: 900;">SCAN FOR REMOTE</div>
                        <div style="color: #aaa; font-size: 2vh;">Control the arcade ticker from your phone</div>
                    </div>
                </div>
                <button class="r-btn" style="width: auto; padding: 2vh 5vh; margin: 0; border-color: #00ffff;" onclick="toggleSettings()">SAVE & CLOSE</button>
            </div>
        </div>
    </div>

    <script>
        const bc = new BroadcastChannel('cinema_channel');
        let rotationStep = 0, slideTimer, cursorTimer, globalLiveGamesData = [], globalTVGuideData = [], globalRawGames = [];

        const defaultSettings = { 
            nfl:true, nba:true, nhl:true, mlb:true, rankings:true, odds:true, tvGuide:true, news:true, mySquad:true, ufc:true,
            showNFL:true, showNBA:true, showNHL:true, showMLB:true, showCFB:true, showCBB:true, showCLB:true,
            cbb50:true, cfb75:true, clb50:true, apiBase:"https://site.api.espn.com/apis",
            mySquadTeams: "Hurricanes, Ohio State",
            marqueeMessage: "WELCOME TO THE ARCADE"
        };
        let settings = JSON.parse(localStorage.getItem('ahlersArcadeSettings')) || defaultSettings;

        function updateSettings() {
            Object.keys(defaultSettings).forEach(k => { 
                const el = document.getElementById('set-'+k); 
                if(el) {
                    if(el.type === 'checkbox') settings[k] = el.checked;
                    else settings[k] = el.value;
                }
            });
            localStorage.setItem('ahlersArcadeSettings', JSON.stringify(settings));
            bcSend('settingsUpdated', settings);
        }
        function loadSettingsUI() { 
            Object.keys(defaultSettings).forEach(k => { 
                const el = document.getElementById('set-'+k); 
                if(el) {
                    if(el.type === 'checkbox') el.checked = settings[k];
                    else el.value = settings[k];
                }
            }); 
            
            const remoteUrl = window.location.href.split('#')[0] + '#remote';
            document.getElementById('settings-qr').src = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(remoteUrl)}&color=0a0a0a&bgcolor=00ffff`;
        }
        function toggleSettings() { const modal = document.getElementById('settings-modal'); modal.style.display = (modal.style.display === 'flex') ? 'none' : 'flex'; }
        function checkMode() { if (window.location.hash === '#remote') document.body.classList.add('remote-active'); }
        
        function scheduleDailyRefresh() {
            const now = new Date();
            let refreshTime = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 4, 0, 0, 0); 
            if (now > refreshTime) refreshTime.setDate(refreshTime.getDate() + 1); 
            setTimeout(() => { window.location.reload(true); }, refreshTime - now);
        }

        window.addEventListener('load', () => { 
            checkMode(); 
            loadSettingsUI(); 
            scheduleDailyRefresh(); 
        });

        function bcSend(action, ...args) { if (document.body.classList.contains('remote-active')) bc.postMessage({ action, args }); executeLocal(action, args); }
        bc.onmessage = (ev) => executeLocal(ev.data.action, ev.data.args);
        function executeLocal(action, args) { 
            if (action === 'forceNext') { clearTimeout(slideTimer); nextSlide(); } 
            if (action === 'settingsUpdated') { settings = args[0]; loadSettingsUI(); updateSportsTicker(); }
        }

        function isLeagueActive(league) {
            const m = new Date().getMonth();
            if (league === 'nfl') return (m >= 7 || m <= 1); 
            if (league === 'cfb') return (m >= 7 || m === 0); 
            if (league === 'cbb') return (m >= 10 || m <= 3); 
            if (league === 'clb') return (m >= 1 || m <= 5);
            if (league === 'nba' || league === 'nhl') return (m >= 9 || m <= 5); 
            if (league === 'mlb') return (m >= 2 && m <= 10); 
            return false;
        }

        function getNetworkLogo(networkStr) {
            const n = networkStr.toUpperCase();
            const domains = {
                'ESPN+': 'plus.espn.com', 'ESPN2': 'espn.com', 'ESPNU': 'espn.com', 'ESPNEWS': 'espn.com', 'ESPN3': 'espn.com', 'ESPN': 'espn.com',
                'SEC': 'secsports.com', 'ACC': 'theacc.com', 'BTN': 'btn.com', 'BIG TEN': 'btn.com', 'FS1': 'foxsports.com', 'FS2': 'foxsports.com',
                'FOX': 'fox.com', 'CBSSN': 'cbssports.com', 'CBS': 'cbs.com', 'NBCSN': 'nbcsports.com', 'NBC': 'nbc.com', 'ABC': 'abc.com',
                'CW': 'cwtv.com', 'TNT': 'tntdrama.com', 'TBS': 'tbs.com', 'TRUTV': 'trutv.com', 'USA': 'usanetwork.com', 'NBATV': 'nba.com',
                'NHLN': 'nhl.com', 'NFL': 'nfl.com', 'MLB': 'mlb.com', 'GOLF': 'golfchannel.com', 'APPLE': 'tv.apple.com', 'PEACOCK': 'peacocktv.com',
                'PRIME': 'primevideo.com', 'YOUTUBE': 'youtube.com', 'PARAMOUNT': 'paramountplus.com', 'YES': 'yesnetwork.com', 'NESN': 'nesn.com',
                'MSG': 'msgnetworks.com', 'MARQUEE': 'marqueesportsnetwork.com', 'SPECTRUM': 'spectrum.com', 'BALLY': 'ballysports.com',
                'FANDUEL': 'fanduel.com', 'SPORTSNET': 'sportsnet.ca', 'TSN': 'tsn.ca'
            };
            for (let key in domains) {
                if (n.includes(key)) {
                    const imgUrl = `https://www.google.com/s2/favicons?domain=${domains[key]}&sz=128`;
                    return `<div style="display:flex; align-items:center; justify-content:center; gap:1.5vw;"><img src="${imgUrl}" alt="${networkStr}" style="border-radius:1vh;" onerror="this.style.display='none'"><span>${networkStr}</span></div>`;
                }
            }
            return `<span class="fallback-logo">${networkStr}</span>`;
        }

        function nextSlide() {
            clearTimeout(slideTimer);
            if (rotationStep > 10) rotationStep = 0; 
            if (rotationStep === 0) {
                if (globalLiveGamesData.length > 0) { renderLivePage(); rotationStep++; return; }
                else { rotationStep++; nextSlide(); return; }
            }
            const screens = [null, 'mySquad', 'ufc', 'tvGuide', 'news', 'odds', 'rankings', 'nfl', 'nba', 'nhl', 'mlb'];
            const current = screens[rotationStep];
            if (!settings[current] || (!isLeagueActive(current) && !['odds', 'rankings', 'tvGuide', 'news', 'mySquad', 'ufc'].includes(current))) { rotationStep++; nextSlide(); return; }

            if (rotationStep === 1) showMySquad();
            else if (rotationStep === 2) showUFC();
            else if (rotationStep === 3) showTVGuide();
            else if (rotationStep === 4) showNews();
            else if (rotationStep === 5) showOdds(); 
            else if (rotationStep === 6) showRankings();
            else if (rotationStep === 7) showStandings('nfl', 'football');
            else if (rotationStep === 8) showStandings('nba', 'basketball');
            else if (rotationStep === 9) showStandings('nhl', 'hockey');
            else if (rotationStep === 10) showStandings('mlb', 'baseball');
            rotationStep++;
        }

        async function showUFC() {
            try {
                const res = await fetch(`${settings.apiBase}/site/v2/sports/mma/ufc/scoreboard`);
                if(!res.ok) { rotationStep++; nextSlide(); return; }
                const d = await res.json();
                
                if(!d.events || d.events.length === 0) { rotationStep++; nextSlide(); return; }
                
                let title = d.events[0].name || "UFC FIGHT NIGHT"; 
                document.getElementById('ufc-title').innerText = title.toUpperCase();

                let fights = [];
                d.events[0].competitions.forEach(fight => {
                    const status = fight.status.type;
                    const f1 = fight.competitors[0];
                    const f2 = fight.competitors[1];
                    
                    let f1Rec = f1.records && f1.records.length > 0 ? f1.records[0].summary : '';
                    let f2Rec = f2.records && f2.records.length > 0 ? f2.records[0].summary : '';

                    fights.push({
                        weightClass: fight.type?.text || "Bout",
                        f1: f1,
                        f2: f2,
                        f1Rec: f1Rec,
                        f2Rec: f2Rec,
                        status: status,
                        clock: fight.status.displayClock,
                        period: fight.status.period
                    });
                });

                if(fights.length === 0) { rotationStep++; nextSlide(); return; }

                document.querySelectorAll('.slide-screen').forEach(el => el.style.display = 'none');
                document.getElementById('ufc-screen').style.display = 'flex';
                
                const track = document.getElementById('ufc-grid-track');
                track.innerHTML = fights.map(f => {
                    
                    let f1Img = f.f1.athlete?.headshot?.href || `https://a.espncdn.com/combiner/i?img=/i/headshots/mma/players/full/${f.f1.id}.png&h=150&w=150&scale=crop`;
                    let f2Img = f.f2.athlete?.headshot?.href || `https://a.espncdn.com/combiner/i?img=/i/headshots/mma/players/full/${f.f2.id}.png&h=150&w=150&scale=crop`;
                    
                    let f1Class = "fighter-img";
                    let f2Class = "fighter-img";
                    let resultMeta = f.weightClass;
                    
                    if(f.status.state === 'post') {
                        if(f.f1.winner) { f1Class += " winner"; f2Class += " loser"; resultMeta = `<span class="ufc-result">${f.status.detail}</span>`; }
                        else if(f.f2.winner) { f2Class += " winner"; f1Class += " loser"; resultMeta = `<span class="ufc-result">${f.status.detail}</span>`; }
                        else { resultMeta = `<span class="ufc-result" style="color:#facc15;">DRAW</span>`; }
                    }

                    let liveBadge = f.status.state === 'in' ? `<div class="ufc-live-badge">RND ${f.period} • ${f.clock}</div>` : '';
                    let f1RecHtml = f.f1Rec ? `<div style="color:#00ffff; font-size:2.2vh; margin-top:0.5vh; font-weight:bold; letter-spacing:0.1vw;">${f.f1Rec}</div>` : '';
                    let f2RecHtml = f.f2Rec ? `<div style="color:#00ffff; font-size:2.2vh; margin-top:0.5vh; font-weight:bold; letter-spacing:0.1vw;">${f.f2Rec}</div>` : '';

                    return `
                    <div class="ufc-card">
                        ${liveBadge}
                        <div class="ufc-matchup">
                            <div class="fighter-col">
                                <img src="${f2Img}" class="${f2Class}" onerror="this.src='https://a.espncdn.com/combiner/i?img=/i/headshots/mma/players/full/default.png'">
                                <div class="fighter-name">${f.f2.athlete.shortName}</div>
                                ${f2RecHtml}
                            </div>
                            <div class="ufc-center">
                                <div class="ufc-vs">VS</div>
                            </div>
                            <div class="fighter-col">
                                <img src="${f1Img}" class="${f1Class}" onerror="this.src='https://a.espncdn.com/combiner/i?img=/i/headshots/mma/players/full/default.png'">
                                <div class="fighter-name">${f.f1.athlete.shortName}</div>
                                ${f1RecHtml}
                            </div>
                        </div>
                        <div class="ufc-meta">
                            <span>${f.status.state === 'post' ? 'FINAL' : f.weightClass}</span>
                            ${f.status.state === 'post' ? resultMeta : ''}
                        </div>
                    </div>
                    `;
                }).join('');

                const vH = document.getElementById('ufc-viewport').clientHeight, fH = track.scrollHeight;
                if (fH > vH) { const sD = fH - vH + 100; track.style.setProperty('--scroll-end', `-${sD}px`); track.style.animation = `scrollVerticalOnePass ${sD/50}s linear forwards`; slideTimer = setTimeout(nextSlide, (sD/50 * 1000) + 3000); } else { slideTimer = setTimeout(nextSlide, 15000); }
                
            } catch(e) {
                rotationStep++; nextSlide();
            }
        }

        async function showMySquad() {
            if(!settings.mySquad || !settings.mySquadTeams) { rotationStep++; nextSlide(); return; }
            const teams = settings.mySquadTeams.split(',').map(t => t.trim().toLowerCase()).filter(t => t);
            if(teams.length === 0) { rotationStep++; nextSlide(); return; }

            document.querySelectorAll('.slide-screen').forEach(el => el.style.display = 'none');
            document.getElementById('mysquad-screen').style.display = 'flex';

            let gamesHtml = "";
            globalRawGames.forEach(g => {
                if(teams.some(t => g.searchString.includes(t))) {
                    gamesHtml += g.html;
                }
            });
            if(gamesHtml === "") gamesHtml = `<div style="text-align:center; color:#aaa; font-size:3vh; margin-top:5vh; border: 2px dashed #333; padding: 4vh; border-radius: 1vh;">NO GAMES IN CURRENT SCHEDULE<br><span style="font-size:2vh; color:#555; margin-top:1vh; display:block;">(API only tracks daily/weekly active blocks)</span></div>`;
            document.getElementById('squad-games-track').innerHTML = gamesHtml;

            let newsHtml = "";
            try {
                let combinedNews = [];
                for (const team of teams) {
                    const rssUrl = `https://news.google.com/rss/search?q=${encodeURIComponent(team + ' sports')}&hl=en-US&gl=US&ceid=US:en`;
                    const res = await fetch(`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(rssUrl)}`);
                    const data = await res.json();
                    if (data.status === 'ok' && data.items) {
                        data.items.slice(0, 3).forEach(item => {
                            let txt = document.createElement("textarea"); txt.innerHTML = item.title;
                            combinedNews.push({ title: txt.value, time: new Date(item.pubDate.replace(/-/g, '/')).getTime(), teamTag: team.toUpperCase() });
                        });
                    }
                }
                combinedNews.sort((a,b) => b.time - a.time);
                newsHtml = combinedNews.slice(0, 8).map(n => `
                    <div class="squad-news-card">
                        <div style="color:#ff007f; font-size:2vh; font-weight:900; margin-bottom:0.5vh;">${n.teamTag} NEWS</div>
                        <div style="color:white; font-size:3vh; font-weight:700; line-height:1.2;">${n.title}</div>
                    </div>
                `).join('');
                if(newsHtml === "") newsHtml = `<div style="text-align:center; color:#aaa; font-size:3vh; margin-top:5vh; border: 2px dashed #333; padding: 4vh; border-radius: 1vh;">NO RECENT HEADLINES</div>`;
            } catch(e) {
                newsHtml = `<div style="text-align:center; color:#ff0000; font-size:3vh; margin-top:5vh;">NEWS FEED UNAVAILABLE</div>`;
            }
            document.getElementById('squad-news-track').innerHTML = newsHtml;

            const vH = document.getElementById('mysquad-viewport').clientHeight;
            const gH = document.getElementById('squad-games-track').scrollHeight;
            const nH = document.getElementById('squad-news-track').scrollHeight;
            const maxH = Math.max(gH, nH);

            if (maxH > vH) { 
                const sD = maxH - vH + 100; 
                document.getElementById('squad-games-track').style.setProperty('--scroll-end', `-${sD}px`); 
                document.getElementById('squad-news-track').style.setProperty('--scroll-end', `-${sD}px`); 
                document.getElementById('squad-games-track').style.animation = `scrollVerticalOnePass ${sD/30}s linear forwards`; 
                document.getElementById('squad-news-track').style.animation = `scrollVerticalOnePass ${sD/30}s linear forwards`; 
                slideTimer = setTimeout(nextSlide, (sD/30 * 1000) + 4000); 
            } else { 
                slideTimer = setTimeout(nextSlide, 15000); 
            }
        }

        async function showNews() {
            try {
                const sources = [
                    { url: 'https://api.rss2json.com/v1/api.json?rss_url=https%3A%2F%2Fsports.yahoo.com%2Frss%2F', name: 'YAHOO SPORTS' },
                    { url: 'https://api.rss2json.com/v1/api.json?rss_url=https%3A%2F%2Fwww.cbssports.com%2Frss%2Fheadlines%2F', name: 'CBS SPORTS' }
                ];
                let combinedNews = [];
                for (const src of sources) {
                    try {
                        const res = await fetch(src.url);
                        const data = await res.json();
                        if (data.status === 'ok') {
                            data.items.forEach(item => {
                                let img = item.thumbnail || (item.enclosure && item.enclosure.link) || '';
                                if (!img && item.description) { const match = item.description.match(/src="([^"]+)"/); if (match) img = match[1]; }
                                let txt = document.createElement("textarea"); txt.innerHTML = item.title;
                                combinedNews.push({ title: txt.value, img: img, source: src.name, time: new Date(item.pubDate.replace(/-/g, '/')).getTime() });
                            });
                        }
                    } catch(e) {}
                }
                if (combinedNews.length === 0) { rotationStep++; nextSlide(); return; }
                combinedNews.sort((a,b) => b.time - a.time);
                
                document.querySelectorAll('.slide-screen').forEach(el => el.style.display = 'none');
                document.getElementById('news-screen').style.display = 'flex';
                const track = document.getElementById('news-list-track');
                track.innerHTML = combinedNews.slice(0, 12).map(item => {
                    const imgHtml = item.img ? `<img class="news-thumb" src="${item.img}" onerror="this.style.display='none'">` : `<div class="news-thumb" style="display:flex;align-items:center;justify-content:center;color:#ff007f;font-weight:900;font-size:3vh;">NEWS</div>`;
                    return `<div class="news-row">${imgHtml}<div class="news-content"><div class="news-title">${item.title}</div><div class="news-source">${item.source}</div></div></div>`;
                }).join('');
                
                const vH = document.getElementById('news-viewport').clientHeight, fH = track.scrollHeight;
                if (fH > vH) { const sD = fH - vH + 100; track.style.setProperty('--scroll-end', `-${sD}px`); track.style.animation = `scrollVerticalOnePass ${sD/40}s linear forwards`; slideTimer = setTimeout(nextSlide, (sD/40 * 1000) + 3000); } else { slideTimer = setTimeout(nextSlide, 15000); }
            } catch(e) { rotationStep++; nextSlide(); }
        }

        function showTVGuide() {
            if(!settings.tvGuide || globalTVGuideData.length === 0) { rotationStep++; nextSlide(); return; }
            document.querySelectorAll('.slide-screen').forEach(el => el.style.display = 'none');
            document.getElementById('tvguide-screen').style.display = 'flex';
            let sorted = [...globalTVGuideData].sort((a,b) => a.network.localeCompare(b.network) || a.timestamp - b.timestamp);
            const track = document.getElementById('tvguide-track');
            track.innerHTML = sorted.map(g => `<div class="tv-row"><div class="tv-channel">${getNetworkLogo(g.network)}</div><div class="tv-program"><div class="tv-prog-title">${g.matchup}</div><div class="tv-prog-time">${g.time}</div>${g.isLive ? '<div class="tv-prog-live">● LIVE</div>' : ''}</div></div>`).join('');
            const vH = document.getElementById('tvguide-viewport').clientHeight, fH = track.scrollHeight;
            if (fH > vH) { const sD = fH - vH + 100; track.style.setProperty('--scroll-end', `-${sD}px`); track.style.animation = `scrollVerticalOnePass ${sD/40}s linear forwards`; slideTimer = setTimeout(nextSlide, (sD/40 * 1000) + 3000); } else { slideTimer = setTimeout(nextSlide, 15000); }
        }

        async function updateSportsTicker() { 
            globalTVGuideData = [];
            globalRawGames = []; 
            const configs = [{l:'nhl',s:'hockey',id:'nhl',t:'showNHL'},{l:'nfl',s:'football',id:'nfl',t:'showNFL'},{l:'nba',s:'basketball',id:'nba',t:'showNBA'},{l:'mlb',s:'baseball',id:'mlb',t:'showMLB'},{l:'college-football',s:'football',g:80,id:'cfb',t:'showCFB'},{l:'mens-college-basketball',s:'basketball',g:settings.cbb50?50:null,id:'cbb',t:'showCBB'},{l:'college-baseball',s:'baseball',id:'clb',t:'showCLB'}];
            let allLive = [], allSched = [], livePage = [];
            const now = new Date(), tomorrow = new Date(now.getTime() + 86400000);
            
            for (const c of configs) { 
                if (!isLeagueActive(c.id) || !settings[c.t]) continue;
                try { 
                    const d = await (await fetch(`${settings.apiBase}/site/v2/sports/${c.s}/${c.l}/scoreboard${c.g?'?groups='+c.g:''}`)).json(); 
                    d.events.forEach(ev => { 
                        const comp = ev.competitions[0], status = comp.status.type;
                        if (c.id === 'clb' && !comp.competitors.some(team => team.curatedRank && team.curatedRank.current <= (settings.clb50 ? 50 : 25))) return;
                        
                        const h = comp.competitors[0], a = comp.competitors[1];
                        const tv = comp.broadcasts?.[0]?.names?.[0] || 'TV';
                        const statusText = (c.id === 'mlb' || c.id === 'clb') ? (comp.status.type.detail) : status.shortDetail;
                        
                        globalRawGames.push({
                            searchString: (h.team.displayName + " " + a.team.displayName).toLowerCase(),
                            html: `<div class="squad-game-card"><div class="card-meta"><span>${c.id.toUpperCase()}</span><span style="color:#00ff00">${tv}</span></div><div class="card-row"><div class="card-team"><img src="${a.team.logo}">${a.team.shortDisplayName}</div><div class="card-val-lg">${(status.state === 'in' || status.state === 'post') ? a.score : ''}</div></div><div class="card-row"><div class="card-team"><img src="${h.team.logo}">${h.team.shortDisplayName}</div><div class="card-val-lg">${(status.state === 'in' || status.state === 'post') ? h.score : ''}</div></div><div class="card-footer" style="justify-content:center; color:#39ff14;">${status.state === 'pre' ? new Date(ev.date).toLocaleDateString([],{weekday:'short'}) + ' ' + new Date(ev.date).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}) : statusText}</div></div>`
                        });

                        if (status.state === 'in' || status.state === 'post' || (new Date(ev.date) > now && new Date(ev.date) < tomorrow)) { 
                            if (tv !== 'TV' && status.state === 'in') {
                                const matchupStr = `${a.team.shortDisplayName} @ ${h.team.shortDisplayName}`;
                                if (!globalTVGuideData.some(g => g.matchup === matchupStr)) {
                                    globalTVGuideData.push({ network: tv, matchup: matchupStr, time: 'LIVE RIGHT NOW', isLive: true, timestamp: new Date(ev.date).getTime() });
                                }
                            }
                            if (status.state === 'in') {
                                allLive.push({ html: `<span class="score-item"><span class="live-pulse">●</span><div class="team-box"><img class="team-logo" src="${a.team.logo}"><span class="team-score">${a.score}</span></div><span class="vs-label">@</span><div class="team-box"><img class="team-logo" src="${h.team.logo}"><span class="team-score">${h.score}</span></div><span class="game-status">${statusText}</span></span>`, league: c.id.toUpperCase() });
                                livePage.push({ league: c.id.toUpperCase(), home: h.team.shortDisplayName, hScore: h.score, hLogo: h.team.logo, away: a.team.shortDisplayName, aScore: a.score, aLogo: a.team.logo, status: statusText, tv: tv, clock: comp.status.displayClock || status.detail });
                            } else {
                                allSched.push({ html: `<span class="score-item"><div class="team-box"><img class="team-logo" src="${a.team.logo}"></div><span class="vs-label">vs</span><div class="team-box"><img class="team-logo" src="${h.team.logo}"></div><span class="game-status" style="color:#00ffff">${comp.odds?.[0]?.details || "LINE TBD"} • ${new Date(ev.date).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}</span></span>`, league: c.id.toUpperCase() });
                            }
                        } 
                    });
                } catch(e) {} 
            }
            globalLiveGamesData = livePage;
            let content = "";
            if (allLive.length > 0) {
                content += `<div class="live-mode-header"><span class="live-pulse">●</span> LIVE SCORES</div>`;
                const sorted = allLive.reduce((acc, g) => { if(!acc[g.league]) acc[g.league]=[]; acc[g.league].push(g.html); return acc; }, {});
                for(const [l, gs] of Object.entries(sorted)) content += `<span class="ticker-section-head">${l}</span>` + gs.join('');
            } else { allSched.forEach(g => content += `<span class="ticker-section-head">${g.league}</span>` + g.html); }
            
            if (settings.marqueeMessage && settings.marqueeMessage.trim() !== '') {
                content += `<span class="score-item"><span style="color:#fff; font-size:4rem; font-weight:900; letter-spacing:0.2vw; text-shadow:0 0 15px #ff007f; margin-left: 5vw;">••• ${settings.marqueeMessage.toUpperCase()} •••</span></span>`;
            }

            document.getElementById('ticker-track').innerHTML = content + content;
        }

        function renderLivePage() {
            document.querySelectorAll('.slide-screen').forEach(el => el.style.display = 'none');
            document.getElementById('live-game-screen').style.display = 'flex';
            const track = document.getElementById('live-grid-track');
            track.innerHTML = globalLiveGamesData.map(g => `<div class="info-card live-card"><div class="card-meta"><span style="color:red">● LIVE</span><span>${g.league}</span><span>${g.status}</span></div><div class="card-row"><div class="card-team"><img src="${g.aLogo}">${g.away}</div><div class="card-val-lg">${g.aScore}</div></div><div class="card-row"><div class="card-team"><img src="${g.hLogo}">${g.home}</div><div class="card-val-lg">${g.hScore}</div></div><div class="card-footer"><span>${(g.clock === '0:00' ? '' : g.clock)}</span><span style="color:#00ff00">${g.tv}</span></div></div>`).join('');
            const vH = document.getElementById('live-viewport').clientHeight, fH = track.scrollHeight;
            if (fH > vH) { const sD = fH - vH + 100; track.style.setProperty('--scroll-end', `-${sD}px`); track.style.animation = `scrollVerticalOnePass ${sD/50}s linear 2s forwards`; slideTimer = setTimeout(nextSlide, (sD/50 * 1000) + 5000); } else { slideTimer = setTimeout(nextSlide, 15000); }
        }

        async function showOdds() {
            let games = [];
            const leagues = [{id:'nfl',s:'football',t:'showNFL'},{id:'nba',s:'basketball',t:'showNBA'},{id:'nhl',s:'hockey',t:'showNHL'},{id:'mlb',s:'baseball',t:'showMLB'},{id:'mens-college-basketball',s:'basketball',t:'showCBB',g:settings.cbb50?50:null},{id:'college-baseball',s:'baseball',t:'showCLB'}];
            for (const l of leagues) {
                if(!isLeagueActive(l.id==='mens-college-basketball'?'cbb':l.id==='college-baseball'?'clb':l.id) || !settings[l.t]) continue;
                try {
                    const d = await (await fetch(`${settings.apiBase}/site/v2/sports/${l.s}/${l.id}/scoreboard${l.g?'?groups='+l.g:''}`)).json();
                    d.events.forEach(ev => { 
                        const comp = ev.competitions[0];
                        if(comp.status.type.state === 'pre') {
                            games.push({ l: (l.id==='mens-college-basketball'?'CBB':l.id==='college-baseball'?'BASEBALL':l.id.toUpperCase()), t:new Date(ev.date).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}), h:comp.competitors[0].team, a:comp.competitors[1].team, o:comp.odds?.[0]?.details || 'EVEN', ou:comp.odds?.[0]?.overUnder || '--', tv:comp.broadcasts?.[0]?.names?.[0] || 'TV' });
                        }
                    });
                } catch(e) {}
            }
            if(games.length === 0) { rotationStep++; nextSlide(); return; }
            document.querySelectorAll('.slide-screen').forEach(el => el.style.display = 'none');
            document.getElementById('odds-screen').style.display = 'flex';
            const track = document.getElementById('odds-grid-track');
            track.innerHTML = games.map(g => `<div class="info-card"><div class="card-meta"><span>${g.l}</span><span style="color:#facc15">${g.t}</span></div><div class="card-row"><div class="card-team"><img src="${g.a.logo}">${g.a.shortDisplayName}</div><div class="card-val-lg"></div></div><div class="card-row"><div class="card-team"><img src="${g.h.logo}">${g.h.shortDisplayName}</div><div class="card-val-lg"></div></div><div class="card-footer"><span style="color:#facc15">${g.o}</span><span style="color:#00ff00">${g.tv}</span><span style="color:#aaa">O/U ${g.ou}</span></div></div>`).join('');
            const vH = document.getElementById('odds-viewport').clientHeight, fH = track.scrollHeight;
            if (fH > vH) { const sD = fH - vH + 100; track.style.setProperty('--scroll-end', `-${sD}px`); track.style.animation = `scrollVerticalOnePass ${sD/50}s linear forwards`; slideTimer = setTimeout(nextSlide, (sD/50 * 1000) + 3000); } else { slideTimer = setTimeout(nextSlide, 15000); }
        }

        async function showRankings() {
            try {
                let html = "";
                const types = [{p:'football/college-football',l:settings.cfb75?75:25,h:'CFB',t:'showCFB'},{p:'basketball/mens-college-basketball',l:25,h:'CBB',t:'showCBB'},{p:'baseball/college-baseball',l:settings.clb50?50:25,h:'CLB',t:'showCLB'}];
                for(const t of types) {
                    if(!isLeagueActive(t.h.toLowerCase()) || !settings[t.t]) continue;
                    try {
                        const res = await fetch(`${settings.apiBase}/site/v2/sports/${t.p}/rankings`);
                        if(!res.ok) continue;
                        const d = await res.json();
                        if(d.rankings && d.rankings.length > 0 && d.rankings[0].ranks) {
                            html += `<div style="font-size:4vh; color:#ff007f; font-weight:900; margin:4vh 0 2vh 0; border-bottom:2px solid #ff007f; padding-bottom:1vh;">${t.h} RANKINGS</div>`;
                            html += d.rankings[0].ranks.slice(0, t.l).map(r => `<div class="rank-row"><span class="rank-num">${r.current}</span><img class="rank-logo" src="${r.team.logo}"><span><span class="rank-name">${r.team.nickname}</span></span><span class="rank-rec">${r.recordSummary || '0-0'}</span></div>`).join('');
                        }
                    } catch(e) {}
                }
                if(!html) { rotationStep++; nextSlide(); return; }
                document.querySelectorAll('.slide-screen').forEach(el => el.style.display = 'none');
                document.getElementById('rankings-screen').style.display = 'flex';
                document.getElementById('rankings-list-track').innerHTML = html;
                const vH = document.getElementById('rankings-viewport').clientHeight, fH = document.getElementById('rankings-list-track').scrollHeight;
                if (fH > vH) { const sD = fH - vH + 100; document.getElementById('rankings-list-track').style.setProperty('--scroll-end', `-${sD}px`); document.getElementById('rankings-list-track').style.animation = `scrollVerticalOnePass ${sD/40}s linear forwards`; slideTimer = setTimeout(nextSlide, (sD/40 * 1000) + 3000); } else { slideTimer = setTimeout(nextSlide, 15000); }
            } catch(e) { rotationStep++; nextSlide(); }
        }

        async function showStandings(l, s) {
            try {
                const d = await (await fetch(`${settings.apiBase}/v2/sports/${s}/${l}/standings`)).json();
                document.querySelectorAll('.slide-screen').forEach(el => el.style.display = 'none');
                document.getElementById(`${l}-screen`).style.display = 'flex';
                const track = document.getElementById(`${l}-track`);
                let html = "";
                d.children.forEach(group => {
                    html += `<div class="division-block"><div class="division-header">${group.name}</div>`;
                    const entries = group.standings ? group.standings.entries : (group.children ? group.children[0].standings.entries : []);
                    entries.forEach(t => { 
                        const rS = t.stats.find(s => ['record','overall','overallRecord'].includes(s.name) || s.type === 'total');
                        html += `<div class="st-row"><img class="st-logo" src="${t.team.logos[0].href}"><div class="st-name">${t.team.displayName}</div><div class="st-rec">${rS?rS.displayValue:'0-0'}</div></div>`; 
                    });
                    html += `</div>`;
                });
                track.innerHTML = html;
                const vH = document.getElementById(`${l}-viewport`).clientHeight, fH = track.scrollHeight;
                if (fH > vH) { const sD = fH - vH + 100; track.style.setProperty('--scroll-end', `-${sD}px`); track.style.animation = `scrollVerticalOnePass ${sD/50}s linear 2s forwards`; slideTimer = setTimeout(nextSlide, (sD/50 * 1000) + 5000); } else { slideTimer = setTimeout(nextSlide, 15000); }
            } catch(e) { rotationStep++; nextSlide(); }
        }

        function showCursor() { document.body.style.cursor = 'default'; clearTimeout(cursorTimer); cursorTimer = setTimeout(()=>document.body.style.cursor='none', 3000); }
        setInterval(updateSportsTicker, 60000); updateSportsTicker(); nextSlide();
    </script>
</body>
</html>
