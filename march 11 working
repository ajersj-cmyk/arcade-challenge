<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Sportsbook Master Ticker (Ahlers Arcade Edition)</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <style>
        /* --- ORIGINAL MASTER SCALING & STYLES --- */
        :root { --ticker-height: 22vh; }
        body, html { margin: 0; padding: 0; width: 100vw; height: 100vh; background: black; overflow: hidden; color: white; font-family: 'Inter', sans-serif; cursor: none; font-size: 3.5vh; }
        body.remote-active .tv-wrapper { display: none !important; }
        body:not(.remote-active) #remote-controller { display: none !important; }
        .tv-wrapper { position: absolute; top: 0; left: 0; width: 100vw; height: 100vh; display: flex; justify-content: center; align-items: center; overflow: hidden; }

        /* CLEAN FS TOGGLE */
        #fs-toggle { position: fixed; top: 2vh; right: 2vw; z-index: 10000; background: none; border: none; color: #fff; font-size: 4vh; cursor: pointer; opacity: 0.3; transition: all 0.3s ease; }
        #fs-toggle:hover { opacity: 1; color: #ff007f; text-shadow: 0 0 15px #ff007f; }

        /* SETTINGS UI */
        #settings-gear { position: fixed; top: 2vh; right: 8vw; z-index: 15000; font-size: 5vh; cursor: pointer; opacity: 0.2; transition: all 0.3s ease; color: white; }
        #settings-gear:hover { opacity: 1; color: #ff007f; transform: rotate(90deg); }
        #settings-modal { position: fixed; inset: 0; background: rgba(0,0,0,0.95); backdrop-filter: blur(15px); z-index: 20000; display: none; justify-content: center; align-items: center; }
        .settings-card { background: #0a0a0a; border: 2px solid #ff007f; width: 85vw; max-height: 90vh; border-radius: 2vh; padding: 4vh; overflow-y: auto; }
        .settings-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 4vh; }
        .settings-section h3 { color: #ff007f; text-transform: uppercase; font-weight: 900; border-bottom: 1px solid #333; margin-bottom: 2vh; font-size: 2.8vh; }
        .toggle-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5vh; font-size: 2vh; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5vh; }

        /* TICKER - SLOWED BY 25% (80s) */
        #sports-ticker { position: absolute; bottom: 0; left: 0; width: 100%; height: var(--ticker-height); background: rgba(0,0,0,0.95); backdrop-filter: blur(20px); border-top: 0.6vh solid #ff007f; z-index: 100; display: flex; align-items: center; overflow: hidden; white-space: nowrap; box-shadow: 0 -1vh 3vh rgba(255, 0, 127, 0.6); }
        #ticker-track { display: inline-flex; animation: scrollTicker 80s linear infinite; padding-left: 100%; height: 100%; align-items: center; } 
        @keyframes scrollTicker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

        /* TICKER ITEMS - STRICT SIDE-BY-SIDE LOCK */
        .ticker-section-head { display: inline-flex; align-items: center; justify-content: center; padding: 0 3vw; height: 100%; color: #ff007f; font-size: 4rem; letter-spacing: 0.3vw; font-weight: 900; vertical-align: middle; }
        .score-item { display: inline-flex !important; flex-direction: row !important; align-items: center !important; padding: 0 5vw; height: 100%; vertical-align: middle; flex-wrap: nowrap !important; }
        .team-box { display: flex !important; flex-direction: row !important; align-items: center !important; flex-wrap: nowrap !important; }
        .team-logo { width: 11vh; height: 11vh; object-fit: contain; margin-right: 1.5vw; flex-shrink: 0; } 
        .team-score { font-size: 4.8rem; line-height: 1; color: #00ffff; margin-right: 0.8vw; font-weight: 900; }
        .vs-label { color: #444; font-size: 2.7rem; margin: 0 2.5vw; font-weight: bold; }
        .game-status { margin-left: 2vw; color: #facc15; font-size: 2.7rem; text-transform: uppercase; letter-spacing: 0.1vw; }
        .live-pulse { animation: pulseRed 1s infinite; color: #ff0000; font-weight: 900; margin-right: 1.5vw; font-size: 2.7rem; }

        /* SLIDES & GRIDS - STRICT SIDE-BY-SIDE SCORE LOCK */
        .slide-screen { position: absolute; inset: 0; z-index: 10; display: none; flex-direction: column; padding: 2vh 4vh; font-family: 'Share Tech Mono', monospace; align-items: center; overflow: hidden; }
        .screen-header { font-size: 9.5vh; font-weight: 900; color: #fff; text-transform: uppercase; letter-spacing: 1vh; margin-bottom: 2vh; margin-top: 1vh; text-shadow: 0 0 15px rgba(0, 255, 255, 0.9); z-index: 20; border-bottom: 0.6vh solid #00ffff; padding-bottom: 1vh; width: 95%; text-align: center; }
        .content-viewport { width: 95%; height: 62vh; overflow: hidden; position: relative; z-index: 20; padding-bottom: var(--ticker-height); }
        .grid-track { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2vw; padding-bottom: 10vh; }
        .info-card { background: rgba(0, 20, 30, 0.85); border: 1px solid #00aaaa; border-left: 1vh solid #00ffff; border-radius: 1vh; display: flex; flex-direction: column; padding: 2.5vh; box-shadow: 0 0 2vh rgba(0, 255, 255, 0.1); backdrop-filter: blur(5px); }
        .card-row { display: flex !important; flex-direction: row !important; justify-content: space-between !important; align-items: center !important; margin-bottom: 1.5vh; width: 100%; }
        .card-team { display: flex; align-items: center; gap: 2vh; font-size: 5.2vh; font-weight: 900; color: white; text-transform: uppercase; } 
        .card-team img { width: 8.2vh; height: 8.2vh; object-fit: contain; } 
        .card-val-lg { font-weight: 900; color: #facc15; font-size: 5.7vh; } 
        .card-meta { display: flex; justify-content: space-between; border-bottom: 2px solid #004444; padding-bottom: 1vh; margin-bottom: 1.5vh; font-size: 3.5vh; color: #00aaaa; font-weight: 900; }
        .card-footer { margin-top: auto; padding-top: 1.2vh; border-top: 2px dashed #004444; display: flex; justify-content: space-between; align-items: center; color: #aaa; font-size: 3.5vh; }

        /* STANDINGS & LISTS */
        .list-track { display: flex; flex-direction: column; gap: 1.5vh; padding-bottom: 10vh; width: 90%; margin: 0 auto; }
        .rank-row { display: flex; align-items: center; background: rgba(0, 20, 30, 0.9); border-left: 1vh solid #facc15; padding: 2vh 2.5vh; border-radius: 0.8vh; margin-bottom: 1.5vh; width: 100%; }
        .rank-num { font-size: 6.8vh; color: #facc15; font-weight: 900; width: 12vh; text-align: center; }
        .rank-logo { width: 10vh; height: 10vh; object-fit: contain; margin: 0 3vh; }
        .rank-name { font-size: 5.4vh; color: white; font-weight: 900; flex: 1; }
        .rank-rec { font-size: 4.3vh; color: #aaa; margin-left: auto; font-weight: 900; }

        .standings-track { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5vw; width: 100%; padding-bottom: 15vh; }
        .division-block { background: rgba(0, 20, 30, 0.7); border: 1px solid #333; border-radius: 1.2vh; padding: 2vh; margin-bottom: 2.5vh; }
        .division-header { color: #facc15; font-size: 3.8vh; font-weight: 900; text-transform: uppercase; border-bottom: 3px solid #00aaaa; margin-bottom: 1.5vh; }
        .st-row { display: flex; align-items: center; padding: 1vh 0; border-bottom: 1px solid rgba(255,255,255,0.1); font-size: 3.8vh; font-weight: 900; }
        .st-logo { width: 4.8vh; height: 4.8vh; object-fit: contain; margin: 0 1.5vh; }
        .st-name { flex: 1; color: white; text-transform: uppercase; }
        .st-rec { color: #00ffff; font-weight: 900; }

        #main-bg { position: absolute; inset: 0; z-index: 0; background: #050505; overflow: hidden; perspective: 100vh; }
        .cyber-grid { position: absolute; top: 0; left: -50%; width: 200%; height: 100%; background-image: linear-gradient(rgba(0, 255, 255, 0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 255, 255, 0.3) 1px, transparent 1px); background-size: 100px 100px; transform: rotateX(45deg); animation: gridMove 20s linear infinite; }
        @keyframes scrollVerticalOnePass { 0% { transform: translateY(0); } 100% { transform: translateY(var(--scroll-end)); } }

        /* REMOTE */
        #remote-controller { position: fixed; inset: 0; z-index: 9999; background: #000; display: none; flex-direction: column; font-family: 'Inter', sans-serif; color: white; padding: 4vh; }
        body.remote-active #remote-controller { display: flex; }
        .r-btn { width: 100%; padding: 20px; margin-bottom: 10px; background: #1a1a1a; border: 1px solid #333; color: white; font-weight: bold; border-radius: 8px; font-size: 3vh; }
    </style>
</head>
<body onmousemove="showCursor()">

    <div class="tv-wrapper" id="main-wrapper">
        <div id="main-bg"><div class="cyber-grid"></div><div class="scanlines"></div></div>
        <div id="settings-gear" onclick="toggleSettings()">⚙️</div>
        <button id="fs-toggle" onclick="if(!document.fullscreenElement) document.documentElement.requestFullscreen(); else document.exitFullscreen();">⛶</button>

        <div id="live-game-screen" class="slide-screen">
            <div class="screen-header" style="color: #ff0000; text-shadow: 0 0 15px red; border-bottom-color: red;">LIVE ACTION</div>
            <div class="content-viewport" id="live-viewport"><div class="grid-track" id="live-grid-track"></div></div>
        </div>
        <div id="odds-screen" class="slide-screen"><div class="screen-header">TODAY'S LINES</div><div class="content-viewport" id="odds-viewport"><div class="grid-track" id="odds-grid-track"></div></div></div>
        <div id="rankings-screen" class="slide-screen"><div class="screen-header">COLLEGE RANKINGS</div><div class="content-viewport" id="rankings-viewport"><div class="list-track" id="rankings-list-track"></div></div></div>
        <div id="nfl-screen" class="slide-screen"><div class="screen-header">NFL STANDINGS</div><div class="content-viewport" id="nfl-viewport"><div class="standings-track" id="nfl-track"></div></div></div>
        <div id="nba-screen" class="slide-screen"><div class="screen-header">NBA STANDINGS</div><div class="content-viewport" id="nba-viewport"><div class="standings-track" id="nba-track"></div></div></div>
        <div id="nhl-screen" class="slide-screen"><div class="screen-header">NHL STANDINGS</div><div class="content-viewport" id="nhl-viewport"><div class="standings-track" id="nhl-track"></div></div></div>
        <div id="mlb-screen" class="slide-screen"><div class="screen-header">MLB STANDINGS</div><div class="content-viewport" id="mlb-viewport"><div class="standings-track" id="mlb-track"></div></div></div>

        <div id="sports-ticker"><div id="ticker-track">LOADING AHLERS ARCADE...</div></div>
    </div>

    <div id="settings-modal" onclick="if(event.target === this) toggleSettings()">
        <div class="settings-card">
            <h2 style="font-size: 5vh; font-weight: 900; margin-bottom: 4vh; color: #fff; text-align: center;">ARCADE CONTROL CENTER</h2>
            <div class="settings-grid">
                <div class="settings-section">
                    <h3>Standings</h3>
                    <div class="toggle-row"><span>NFL</span> <input type="checkbox" id="set-nfl" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>NBA</span> <input type="checkbox" id="set-nba" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>NHL</span> <input type="checkbox" id="set-nhl" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>MLB</span> <input type="checkbox" id="set-mlb" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>Rankings Slide</span> <input type="checkbox" id="set-rankings" checked onchange="updateSettings()"></div>
                </div>
                <div class="settings-section">
                    <h3>Live/Ticker Data</h3>
                    <div class="toggle-row"><span>NFL</span> <input type="checkbox" id="set-showNFL" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>NBA</span> <input type="checkbox" id="set-showNBA" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>NHL</span> <input type="checkbox" id="set-showNHL" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>MLB</span> <input type="checkbox" id="set-showMLB" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>NCAA FB</span> <input type="checkbox" id="set-showCFB" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>NCAA Hoops</span> <input type="checkbox" id="set-showCBB" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>NCAA Base.</span> <input type="checkbox" id="set-showCLB" checked onchange="updateSettings()"></div>
                </div>
                <div class="settings-section">
                    <h3>Expansions</h3>
                    <div class="toggle-row"><span>CBB Group 50</span> <input type="checkbox" id="set-cbb50" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>CFB Top 75</span> <input type="checkbox" id="set-cfb75" checked onchange="updateSettings()"></div>
                    <div class="toggle-row"><span>Base. Top 50</span> <input type="checkbox" id="set-clb50" checked onchange="updateSettings()"></div>
                </div>
            </div>
            <button class="r-btn" style="margin-top: 4vh; border-color: #00ffff; width: auto; padding: 2vh 5vh;" onclick="toggleSettings()">SAVE & CLOSE</button>
        </div>
    </div>

    <script>
        const bc = new BroadcastChannel('cinema_channel');
        let rotationStep = 0, slideTimer, cursorTimer, globalLiveGamesData = [];

        const defaultSettings = { 
            nfl:true, nba:true, nhl:true, mlb:true, rankings:true, odds:true,
            showNFL:true, showNBA:true, showNHL:true, showMLB:true, showCFB:true, showCBB:true, showCLB:true,
            cbb50:true, cfb75:true, clb50:true, apiBase:"https://site.api.espn.com/apis" 
        };
        let settings = JSON.parse(localStorage.getItem('ahlersArcadeSettings')) || defaultSettings;

        function updateSettings() {
            Object.keys(defaultSettings).forEach(k => { const el = document.getElementById('set-'+k); if(el) settings[k] = el.checked; });
            localStorage.setItem('ahlersArcadeSettings', JSON.stringify(settings));
            bcSend('settingsUpdated', settings);
        }
        function loadSettingsUI() { Object.keys(defaultSettings).forEach(k => { const el = document.getElementById('set-'+k); if(el) el.checked = settings[k]; }); }
        function toggleSettings() { const modal = document.getElementById('settings-modal'); modal.style.display = (modal.style.display === 'flex') ? 'none' : 'flex'; }
        function checkMode() { if (window.location.hash === '#remote') document.body.classList.add('remote-active'); }
        window.addEventListener('load', () => { checkMode(); loadSettingsUI(); });
        function bcSend(action, ...args) { if (document.body.classList.contains('remote-active')) bc.postMessage({ action, args }); executeLocal(action, args); }
        bc.onmessage = (ev) => executeLocal(ev.data.action, ev.data.args);
        function executeLocal(action, args) { 
            if (action === 'forceNext') { clearTimeout(slideTimer); nextSlide(); } 
            if (action === 'settingsUpdated') { settings = args[0]; loadSettingsUI(); updateSportsTicker(); }
        }

        function isLeagueActive(league) {
            const m = new Date().getMonth();
            if (league === 'nfl') return (m >= 7 || m <= 1); 
            if (league === 'cfb') return (m >= 7 || m === 0); 
            if (league === 'cbb') return (m >= 10 || m <= 3); 
            if (league === 'clb') return (m >= 1 || m <= 5);
            if (league === 'nba' || league === 'nhl') return (m >= 9 || m <= 5); 
            if (league === 'mlb') return (m >= 2 && m <= 10); 
            return false;
        }

        function nextSlide() {
            clearTimeout(slideTimer);
            if (rotationStep > 6) rotationStep = 0;
            if (rotationStep === 0) {
                if (globalLiveGamesData.length > 0) { renderLivePage(); rotationStep++; return; }
                else { rotationStep++; nextSlide(); return; }
            }
            const screens = [null, 'odds', 'rankings', 'nfl', 'nba', 'nhl', 'mlb'];
            const current = screens[rotationStep];
            if (!settings[current] || (!isLeagueActive(current) && !['odds', 'rankings'].includes(current))) { rotationStep++; nextSlide(); return; }

            if (rotationStep === 1) showOdds(); 
            else if (rotationStep === 2) showRankings();
            else if (rotationStep === 3) showStandings('nfl', 'football');
            else if (rotationStep === 4) showStandings('nba', 'basketball');
            else if (rotationStep === 5) showStandings('nhl', 'hockey');
            else if (rotationStep === 6) showStandings('mlb', 'baseball');
            rotationStep++;
        }

        async function updateSportsTicker() { 
            const configs = [{l:'nhl',s:'hockey',id:'nhl',t:'showNHL'},{l:'nfl',s:'football',id:'nfl',t:'showNFL'},{l:'nba',s:'basketball',id:'nba',t:'showNBA'},{l:'mlb',s:'baseball',id:'mlb',t:'showMLB'},{l:'college-football',s:'football',g:80,id:'cfb',t:'showCFB'},{l:'mens-college-basketball',s:'basketball',g:settings.cbb50?50:null,id:'cbb',t:'showCBB'},{l:'college-baseball',s:'baseball',id:'clb',t:'showCLB'}];
            let allLive = [], allSched = [], livePage = [];
            const now = new Date(), tomorrow = new Date(now.getTime() + 86400000);
            for (const c of configs) { 
                if (!isLeagueActive(c.id) || !settings[c.t]) continue;
                try { 
                    const d = await (await fetch(`${settings.apiBase}/site/v2/sports/${c.s}/${c.l}/scoreboard${c.g?'?groups='+c.g:''}`)).json(); 
                    d.events.forEach(ev => { 
                        const comp = ev.competitions[0], status = comp.status.type;
                        if (c.id === 'clb' && !comp.competitors.some(team => team.curatedRank && team.curatedRank.current <= (settings.clb50 ? 50 : 25))) return;
                        if (status.state === 'in' || status.state === 'post' || (new Date(ev.date) > now && new Date(ev.date) < tomorrow)) { 
                            const h = comp.competitors[0], a = comp.competitors[1];
                            const tv = comp.broadcasts?.[0]?.names?.[0] || 'TV';
                            const statusText = (c.id === 'mlb' || c.id === 'clb') ? (comp.status.type.detail) : status.shortDetail;
                            if (status.state === 'in') {
                                allLive.push({ html: `<span class="score-item"><span class="live-pulse">●</span><div class="team-box"><img class="team-logo" src="${a.team.logo}"><span class="team-score">${a.score}</span></div><span class="vs-label">@</span><div class="team-box"><img class="team-logo" src="${h.team.logo}"><span class="team-score">${h.score}</span></div><span class="game-status">${statusText}</span></span>`, league: c.id.toUpperCase() });
                                livePage.push({ league: c.id.toUpperCase(), home: h.team.shortDisplayName, hScore: h.score, hLogo: h.team.logo, away: a.team.shortDisplayName, aScore: a.score, aLogo: a.team.logo, status: statusText, tv: tv, clock: comp.status.displayClock || status.detail });
                            } else {
                                allSched.push({ html: `<span class="score-item"><div class="team-box"><img class="team-logo" src="${a.team.logo}"></div><span class="vs-label">vs</span><div class="team-box"><img class="team-logo" src="${h.team.logo}"></div><span class="game-status" style="color:#00ffff">${comp.odds?.[0]?.details || "LINE TBD"} • ${new Date(ev.date).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}</span></span>`, league: c.id.toUpperCase() });
                            }
                        } 
                    });
                } catch(e) {} 
            }
            globalLiveGamesData = livePage;
            let content = "";
            if (allLive.length > 0) {
                content += `<div class="live-mode-header"><span class="live-pulse">●</span> LIVE SCORES</div>`;
                const sorted = allLive.reduce((acc, g) => { if(!acc[g.league]) acc[g.league]=[]; acc[g.league].push(g.html); return acc; }, {});
                for(const [l, gs] of Object.entries(sorted)) content += `<span class="ticker-section-head">${l}</span>` + gs.join('');
            } else { allSched.forEach(g => content += `<span class="ticker-section-head">${g.league}</span>` + g.html); }
            document.getElementById('ticker-track').innerHTML = content + content;
        }

        function renderLivePage() {
            document.querySelectorAll('.slide-screen').forEach(el => el.style.display = 'none');
            document.getElementById('live-game-screen').style.display = 'flex';
            const track = document.getElementById('live-grid-track');
            track.innerHTML = globalLiveGamesData.map(g => `<div class="info-card live-card"><div class="card-meta"><span style="color:red">● LIVE</span><span>${g.league}</span><span>${g.status}</span></div><div class="card-row"><div class="card-team"><img src="${g.aLogo}">${g.away}</div><div class="card-val-lg">${g.aScore}</div></div><div class="card-row"><div class="card-team"><img src="${g.hLogo}">${g.home}</div><div class="card-val-lg">${g.hScore}</div></div><div class="card-footer"><span>${(g.clock === '0:00' ? '' : g.clock)}</span><span style="color:#00ff00">${g.tv}</span></div></div>`).join('');
            const vH = document.getElementById('live-viewport').clientHeight, fH = track.scrollHeight;
            if (fH > vH) { const sD = fH - vH + 100; track.style.setProperty('--scroll-end', `-${sD}px`); track.style.animation = `scrollVerticalOnePass ${sD/50}s linear 2s forwards`; slideTimer = setTimeout(nextSlide, (sD/50 * 1000) + 5000); } else { slideTimer = setTimeout(nextSlide, 15000); }
        }

        async function showOdds() {
            let games = [];
            const leagues = [{id:'nfl',s:'football',t:'showNFL'},{id:'nba',s:'basketball',t:'showNBA'},{id:'nhl',s:'hockey',t:'showNHL'},{id:'mlb',s:'baseball',t:'showMLB'},{id:'mens-college-basketball',s:'basketball',t:'showCBB',g:settings.cbb50?50:null},{id:'college-baseball',s:'baseball',t:'showCLB'}];
            for (const l of leagues) {
                if(!isLeagueActive(l.id==='mens-college-basketball'?'cbb':l.id==='college-baseball'?'clb':l.id) || !settings[l.t]) continue;
                try {
                    const d = await (await fetch(`${settings.apiBase}/site/v2/sports/${l.s}/${l.id}/scoreboard${l.g?'?groups='+l.g:''}`)).json();
                    d.events.forEach(ev => { 
                        const comp = ev.competitions[0];
                        if(comp.status.type.state === 'pre') {
                            const tv = comp.broadcasts?.[0]?.names?.[0] || 'TV';
                            games.push({ l: (l.id==='mens-college-basketball'?'CBB':l.id==='college-baseball'?'BASEBALL':l.id.toUpperCase()), t:new Date(ev.date).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}), h:comp.competitors[0].team, a:comp.competitors[1].team, o:comp.odds?.[0]?.details || 'EVEN', ou:comp.odds?.[0]?.overUnder || '--', tv:tv });
                        }
                    });
                } catch(e) {}
            }
            if(games.length === 0) { rotationStep++; nextSlide(); return; }
            document.querySelectorAll('.slide-screen').forEach(el => el.style.display = 'none');
            document.getElementById('odds-screen').style.display = 'flex';
            const track = document.getElementById('odds-grid-track');
            track.innerHTML = games.map(g => `<div class="info-card"><div class="card-meta"><span>${g.l}</span><span style="color:#facc15">${g.t}</span></div><div class="card-row"><div class="card-team"><img src="${g.a.logo}">${g.a.shortDisplayName}</div><div class="card-val-lg"></div></div><div class="card-row"><div class="card-team"><img src="${g.h.logo}">${g.h.shortDisplayName}</div><div class="card-val-lg"></div></div><div class="card-footer"><span style="color:#facc15">${g.o}</span><span style="color:#00ff00">${g.tv}</span><span style="color:#aaa">O/U ${g.ou}</span></div></div>`).join('');
            const vH = document.getElementById('odds-viewport').clientHeight, fH = track.scrollHeight;
            if (fH > vH) { const sD = fH - vH + 100; track.style.setProperty('--scroll-end', `-${sD}px`); track.style.animation = `scrollVerticalOnePass ${sD/50}s linear forwards`; slideTimer = setTimeout(nextSlide, (sD/50 * 1000) + 3000); } else { slideTimer = setTimeout(nextSlide, 15000); }
        }

        async function showRankings() {
            try {
                let html = "";
                const types = [{p:'football/college-football',l:settings.cfb75?75:25,h:'CFB',t:'showCFB'},{p:'basketball/mens-college-basketball',l:25,h:'CBB',t:'showCBB'},{p:'baseball/college-baseball',l:settings.clb50?50:25,h:'CLB',t:'showCLB'}];
                for(const t of types) {
                    if(!isLeagueActive(t.h.toLowerCase()) || !settings[t.t]) continue;
                    const d = await (await fetch(`${settings.apiBase}/site/v2/sports/${t.p}/rankings`)).json();
                    if(d.rankings) {
                        html += `<div style="font-size:4vh; color:#ff007f; font-weight:900; margin:4vh 0 2vh 0; border-bottom:2px solid #ff007f; padding-bottom:1vh;">${t.h} RANKINGS</div>`;
                        html += d.rankings[0].ranks.slice(0, t.l).map(r => `<div class="rank-row"><span class="rank-num">${r.current}</span><img class="rank-logo" src="${r.team.logo}"><span><span class="rank-name">${r.team.nickname}</span></span><span class="rank-rec">${r.recordSummary}</span></div>`).join('');
                    }
                }
                if(!html) { rotationStep++; nextSlide(); return; }
                document.querySelectorAll('.slide-screen').forEach(el => el.style.display = 'none');
                document.getElementById('rankings-screen').style.display = 'flex';
                document.getElementById('rankings-list-track').innerHTML = html;
                const vH = document.getElementById('rankings-viewport').clientHeight, fH = document.getElementById('rankings-list-track').scrollHeight;
                if (fH > vH) { const sD = fH - vH + 100; document.getElementById('rankings-list-track').style.setProperty('--scroll-end', `-${sD}px`); document.getElementById('rankings-list-track').style.animation = `scrollVerticalOnePass ${sD/40}s linear forwards`; slideTimer = setTimeout(nextSlide, (sD/40 * 1000) + 3000); } else { slideTimer = setTimeout(nextSlide, 15000); }
            } catch(e) { rotationStep++; nextSlide(); }
        }

        async function showStandings(l, s) {
            try {
                const d = await (await fetch(`${settings.apiBase}/v2/sports/${s}/${l}/standings`)).json();
                document.querySelectorAll('.slide-screen').forEach(el => el.style.display = 'none');
                document.getElementById(`${l}-screen`).style.display = 'flex';
                const track = document.getElementById(`${l}-track`);
                let html = "";
                d.children.forEach(group => {
                    html += `<div class="division-block"><div class="division-header">${group.name}</div>`;
                    const entries = group.standings ? group.standings.entries : (group.children ? group.children[0].standings.entries : []);
                    entries.forEach(t => { 
                        const rS = t.stats.find(s => ['record','overall','overallRecord'].includes(s.name) || s.type === 'total');
                        html += `<div class="st-row"><img class="st-logo" src="${t.team.logos[0].href}"><div class="st-name">${t.team.displayName}</div><div class="st-rec">${rS?rS.displayValue:'0-0'}</div></div>`; 
                    });
                    html += `</div>`;
                });
                track.innerHTML = html;
                const vH = document.getElementById(`${l}-viewport`).clientHeight, fH = track.scrollHeight;
                if (fH > vH) { const sD = fH - vH + 100; track.style.setProperty('--scroll-end', `-${sD}px`); track.style.animation = `scrollVerticalOnePass ${sD/50}s linear 2s forwards`; slideTimer = setTimeout(nextSlide, (sD/50 * 1000) + 5000); } else { slideTimer = setTimeout(nextSlide, 15000); }
            } catch(e) { rotationStep++; nextSlide(); }
        }

        function showCursor() { document.body.style.cursor = 'default'; clearTimeout(cursorTimer); cursorTimer = setTimeout(()=>document.body.style.cursor='none', 3000); }
        setInterval(updateSportsTicker, 60000); updateSportsTicker(); nextSlide();
    </script>
